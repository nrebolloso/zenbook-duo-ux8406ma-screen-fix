#!/usr/bin/env python3
"""Watch the detachable keyboard for the screen-toggle button (right of F12)
and call `duo top` / `duo both` to toggle the bottom screen.

The button does NOT emit a normal KEY_* event — it appears as
  EV_ABS, code=ABS_MISC (40), value=106
on one of the BT keyboard's input nodes. That's why it can't be bound through
gsettings / cinnamon-settings: the input layer never produces a keysym.

We open every input device named "ASUS Zenbook Duo Keyboard" that exposes
ABS_MISC and select() across them, rescanning if the BT keyboard drops.
"""
import os
import select
import subprocess
import sys
import time

import evdev
from evdev import ecodes

DEVICE_NAME = "ASUS Zenbook Duo Keyboard"
TRIGGER_VALUE = 106
DUO = "/usr/local/bin/duo"
DEBOUNCE_S = 0.4


def find_devices():
    devs = []
    for path in evdev.list_devices():
        try:
            d = evdev.InputDevice(path)
        except OSError:
            continue
        if d.name != DEVICE_NAME:
            d.close()
            continue
        caps = d.capabilities().get(ecodes.EV_ABS, [])
        abs_codes = [c if isinstance(c, int) else c[0] for c in caps]
        if ecodes.ABS_MISC in abs_codes:
            devs.append(d)
        else:
            d.close()
    return devs


def toggle():
    try:
        out = subprocess.check_output(["xrandr", "--query"], text=True)
    except (subprocess.CalledProcessError, FileNotFoundError) as e:
        print(f"xrandr failed: {e}", file=sys.stderr)
        return
    edp2_on = False
    for line in out.splitlines():
        if line.startswith("eDP-2"):
            # "eDP-2 connected WxH+X+Y ..." → active; "eDP-2 connected (..." → off.
            parts = line.split()
            if len(parts) >= 3 and "x" in parts[2] and "+" in parts[2]:
                edp2_on = True
            break
    target = "top" if edp2_on else "both"
    print(f"[{time.strftime('%H:%M:%S')}] eDP-2 was {'ON' if edp2_on else 'OFF'} → {DUO} {target}",
          flush=True)
    subprocess.run([DUO, target], check=False)


def main():
    last_fire = 0.0
    while True:
        devs = find_devices()
        if not devs:
            time.sleep(2)
            continue
        print(f"watching: {[d.path for d in devs]}", flush=True)
        fd_to_dev = {d.fd: d for d in devs}
        rescan = False
        try:
            while not rescan:
                r, _, _ = select.select(fd_to_dev, [], [], 5.0)
                if not r:
                    if not all(os.path.exists(d.path) for d in devs):
                        rescan = True
                    continue
                for fd in r:
                    d = fd_to_dev[fd]
                    try:
                        for ev in d.read():
                            if (ev.type == ecodes.EV_ABS
                                    and ev.code == ecodes.ABS_MISC
                                    and ev.value == TRIGGER_VALUE):
                                now = time.monotonic()
                                if now - last_fire < DEBOUNCE_S:
                                    continue
                                last_fire = now
                                toggle()
                    except OSError:
                        rescan = True
                        break
        finally:
            for d in devs:
                try:
                    d.close()
                except Exception:
                    pass


if __name__ == "__main__":
    main()
